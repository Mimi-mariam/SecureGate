# Database Connection
# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://user:password@localhost:5432/securegate?schema=public"

# NextAuth (Auth.js v5) Session Secret
# Generate with: openssl rand -hex 32
AUTH_SECRET="your-secret-key-at-least-32-characters-hex"

# Resend Email Configuration
# Sign up at https://resend.com to get your API key
RESEND_API_KEY="re_xxxxxxxxxxxx"

# Sender email address
# Use onboarding@resend.dev for testing, or a verified custom domain for production
EMAIL_FROM="SecureGate <onboarding@resend.dev>"

# Application URL
# Update to your production domain when deploying
NEXT_PUBLIC_APP_URL="http://localhost:3000"
